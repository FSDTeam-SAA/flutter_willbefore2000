{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "smilestreats",
          "appId": "1:466892546022:android:ba6444698809c898e40027",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "smilestreats",
          "appId": "1:466892546022:ios:80f9379efa855b3ae40027",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "smilestreats",
          "configurations": {
            "android": "1:466892546022:android:ba6444698809c898e40027",
            "ios": "1:466892546022:ios:80f9379efa855b3ae40027",
            "web": "1:466892546022:web:7db86b825af5071fe40027"
          }
        }
      }
    }
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint"
      ]
    }
  ],
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}